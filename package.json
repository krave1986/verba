{
    "name": "derba",
    "displayName": "Derba",
    "publisher": "krave",
    "description": "Explicit, checkbox-driven context for AI chat — you choose what the model sees",
    "version": "0.0.1",
    "type": "module",
    "engines": {
        "vscode": "^1.116.0"
    },
    "categories": [
        "Other",
        "AI"
    ],
    "icon": "assets/icon.png",
    "license": "MIT",
    "activationEvents": [],
    "main": "./dist/extension.mjs",
    "repository": {
        "type": "git",
        "url": "https://github.com/krave1986/derba.git"
    },
    "keywords": [
        "ai",
        "context",
        "llm",
        "file-tree",
        "prompt"
    ],
    "contributes": {
        "configuration": {
            "title": "Derba",
            "properties": {
                "derba.include": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/*"
                    ],
                    "description": "Glob patterns for files to show in the file selector."
                },
                "derba.exclude": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/.git/",
                        "**/node_modules/",
                        "**/dist/",
                        "**/build/",
                        "**/.vscode/",
                        "**/*.vsix"
                    ],
                    "description": "Glob patterns for files to hide from the file selector."
                },
                "derba.locale": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Locale for date/time display. Leave empty to follow VS Code UI language.",
                    "examples": [
                        "zh-CN",
                        "en-US",
                        "ja-JP",
                        "ko-KR",
                        "fr-FR",
                        "de-DE"
                    ]
                }
            }
        },
        "views": {
            "derba-panel": [
                {
                    "id": "derba.fileSelector",
                    "name": "File Selector",
                    "type": "tree",
                    "icon": "assets/panel-icon.svg"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "derba-panel",
                    "title": "Derba",
                    "icon": "assets/panel-icon.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "derba.temporaryDebug",
                "title": "Derba: Temporary Debug",
                "enablement": "isDevelopment"
            },
            {
                "command": "derba.saveSnapshot",
                "title": "Derba: Save Snapshot"
            },
            {
                "command": "derba.showSnapshotPicker",
                "title": "Derba: Show Snapshots"
            },
            {
                "command": "derba.extractContext",
                "title": "Derba: Extract Context"
            }
        ],
        "keybindings": [
            {
                "command": "workbench.view.extension.derba-panel",
                "key": "shift+alt+v"
            },
            {
                "command": "derba.saveSnapshot",
                "key": "shift+alt+s"
            },
            {
                "command": "derba.showSnapshotPicker",
                "key": "shift+alt+p"
            },
            {
                "command": "derba.temporaryDebug",
                "key": "shift+alt+d",
                "when": "isDevelopment"
            }
        ]
    },
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "vscode-test",
        "bundle": "tsdown --sourcemap",
        "vscode:prepublish": "tsdown --minify",
        "vscode:publish": "vsce publish"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.116.0",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3",
        "tsdown": "^0.22.4"
    },
    "dependencies": {
        "picomatch": "^4.0.4",
        "rxjs": "^7.8.2"
    }
}
