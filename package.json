{
    "name": "verba",
    "displayName": "verba",
    "description": "NDY",
    "version": "0.0.1",
    "type": "module",
    "engines": {
        "vscode": "^1.116.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./src/extension.js",
    "contributes": {
        "configuration": {
            "title": "Verba",
            "properties": {
                "verba.include": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/*"
                    ],
                    "description": "Glob patterns for files to show in the file selector."
                },
                "verba.exclude": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/.git/",
                        "**/node_modules/",
                        "**/dist/",
                        "**/build/",
                        "**/.vscode/",
                        "**/*.vsix"
                    ],
                    "description": "Glob patterns for files to hide from the file selector."
                },
                "verba.collapse": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [],
                    "description": "Glob patterns for directories to collapse by default."
                },
                "verba.locale": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Locale for date/time display. Leave empty to follow VS Code UI language.",
                    "examples": [
                        "zh-CN",
                        "en-US",
                        "ja-JP",
                        "ko-KR",
                        "fr-FR",
                        "de-DE"
                    ]
                }
            }
        },
        "views": {
            "verba-panel": [
                {
                    "id": "verba.fileSelector",
                    "name": "File Selector",
                    "type": "tree",
                    "icon": "assets/panel-icon.svg"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "verba-panel",
                    "title": "Verba",
                    "icon": "assets/panel-icon.svg"
                }
            ]
        },
        "commands": [
            {
                "command": "verba.saveSnapshot",
                "title": "Verba: Save Snapshot"
            },
            {
                "command": "verba.showSnapshotPicker",
                "title": "Verba: Show Snapshots"
            },
            {
                "command": "verba.extractContext",
                "title": "Verba: Extract Context"
            }
        ],
        "keybindings": [
            {
                "command": "workbench.view.extension.verba-panel",
                "key": "shift+alt+v"
            },
            {
                "command": "verba.saveSnapshot",
                "key": "shift+alt+s"
            },
            {
                "command": "verba.showSnapshotPicker",
                "key": "shift+alt+p"
            }
        ]
    },
    "scripts": {
        "lint": "eslint .",
        "pretest": "npm run lint",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.116.0",
        "@vscode/test-electron": "^2.5.2",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.3"
    },
    "dependencies": {
        "picomatch": "^4.0.4",
        "rxjs": "^7.8.2"
    }
}
